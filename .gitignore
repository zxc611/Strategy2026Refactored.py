# ============================================================
# 防膨胀白名单策略
# 规则：默认忽略一切，只放行已追踪的目录结构
# 新增文件必须 git add -f <file> 才能追踪（强制绕过忽略规则）
# 已追踪文件不受影响（git已记录的文件始终可见）
# ============================================================

# === 默认忽略一切 ===
*

# === 放行已追踪的目录结构（仅目录，不含文件） ===
!*/
!strategy/**/
!position/**/
!signal/**/
!order/**/
!risk/**/
!risk_engine/**/
!infra/**/
!config/**/
!data/**/
!lifecycle/**/
!governance/**/
!param_pool/**/
!precompute/**/
!strategy_judgment/**/
!evaluation/**/
!tools/**/
!tests/**/
!docs/**/
!ee_layer_sort/**/
!fra_archived/**/
!scripts/**/

# === 文件类型不放行 — 新增文件必须 git add -f ===
# 已追踪文件不受影响（git已记录的文件始终可见）
# 新增文件必须 git add -f <file> 才能追踪

# === 重新忽略运行时产物（即使类型放行也不追踪） ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing runtime
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.hypothesis/

# Logs and databases
*.log
*.db
*.sqlite3
logs/

# Local configuration
.env
*.local

# Backup files
*.bak
*.backup
backup_*/
backup_v*/
_backup_*/

# Data files
data/
*.duckdb
*.duckdb.wal

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.pyc
*.pyo

# P2-R8-01修复: 运行时参数状态文件
**/state_param_sets.yaml

# 运行时生成文件
**/_wal_orders/
**/.circuit_breaker_state.json
**/idempotent_state.jsonl
**/order_state.jsonl

# 数据库文件
*.duckdb
*.duckdb.wal
*.bak_before_*

# WAL order logs
*.wal

# Signal logs
config/logs/signals.jsonl*

# Lock files
*.lock

# Temporary files
*.tmp
*.temp
